---
import Layout from "../layouts/Layout.astro";
import ArrowLeft from "@astropub/icons/ArrowLeft";

import { Image } from "astro:assets";
import logo from "../assets/pretoi22-logo.png";
import cms from "../assets/cms-gean.png";
import discord from "../assets/discord.png";
---

<Layout title="Gean Dev Pre TOI22">
  <main class="w-full text-white bg-slate-800">
    <div class="h-screen" id="greet">
      <div class="h-full flex justify-center items-center flex-col text-center">
        <Image
          src={logo}
          alt="logo"
          class="object-cover"
          style="max-width: 300px;"
        />
        <h1 class="text-5xl font-bold mt-5">
          <span class="text-red-400">22</span> by <span class="text-orange-500"
            ><a
              href="https://github.com/gean-dev"
              target="_blank"
              rel="noopener">Gean Dev</a
            ></span
          >
        </h1>
        <!-- <h2 class="text-3xl pt-4">
          Gean Dev by Admin <span class="text-red-500"
            ><a href="https://โอถอก.ไทย" target="_blank" rel="noopener"
              >OTOG©</a
            ></span
          >
        </h2> -->
        <div class="text-xl md:text-2xl pt-3">
          <p>
            จัดขึ้น วันที่
            <span
              ><a
                href="https://www.timeanddate.com/worldclock/fixedtime.html?msg=Pre+TOI+22+Day+1&iso=20260418T18&p1=28&ah=5"
                target="_blank"
                rel="noopener"
              >
                <span class="text-cyan-400">18</span>
              </a>
              และ
              <a
                href="https://www.timeanddate.com/worldclock/fixedtime.html?msg=Pre+TOI+22+Day+2&iso=20260419T18&p1=28&ah=5"
                target="_blank"
                rel="noopener"
              >
                <span class="text-cyan-400">19</span>
              </a>
              April 2026
              <span class="text-pink-300">18:00 - 23:00</span>
            </span>
          </p>
          <p>
            ด้วยระบบ
            <span
              ><a
                href="https://cms-dev.github.io/"
                target="_blank"
                rel="noopener"
              >
                <span class="text-yellow-500">CMS</span>
              </a>
              แบบเดียวกับ
              <span class="text-orange-400">TOI</span>
              และ
              <span class="text-red-400">IOI</span>
              <span><a href="#about">😱</a></span>
            </span>
          </p>
          <!-- <button class="rounded-md bg-green-600 px-4 py-2 my-3">
            <a href="ranking/" target="_blank" rel="noopener">
              <p class="text-white text-lg">ดูอันดับการแข่งขัน</p>
            </a>
          </button> -->
          <button class="rounded-md bg-green-600 px-4 py-1 text-sm mt-4">
            <a
              href="#about"
            >
              <p class="text-white">next</p>
            </a>
          </button>
        </div>
      </div>

      <div class="h-screen" id="about">
        <div
          class="h-full flex flex-col justify-center items-center text-center"
        >
          <h2 class="text-3xl font-bold">
            ราย<span class="text-blue-400">ละเอีย</span>ด
          </h2>
          <div class="flex flex-col md:flex-row items-center justify-center text-2xl gap-1">
            <span>มีโจทย์วันละ 3 ข้อ</span>
            <span>แต่ละข้<span class="text-teal-400"
              >อมีคะแนนเ</span
            >ท่ากันที่ <span class="text-yellow-500"
              ><a href="#people">💯</a> คะแ</span
            >นน
            </span>
          </div>
          <button class="rounded-md bg-green-600 px-4 py-1 text-sm mt-4">
            <a
              href="#people"
            >
              <p class="text-white">next</p>
            </a>
          </button>
        </div>
      </div>

      <div class="h-screen" id="people">
        <div class="h-full flex flex-col justify-center items-center">
          <div
            class="grid items-center justify-center grid-cols-3 gap-2 text-center text-l lg:text-2xl"
          >
            <h2 class="col-span-3 text-2xl md:text-3xl font-bold my-5">
              Problems ถูก <span class="text-cyan-300">provided</span> โดย
            </h2>
            <a href="https://codeforces.com/profile/omsincoconut"
              ><p class="pt-1 font-bold text-yellow-500">
                omsincoconut
              </p></a
            >
            <a href="https://codeforces.com/profile/ttamx"
              ><p class="pt-1 text-red-400 font-bold">ttamx</p></a
            >
            <a href="https://codeforces.com/profile/kunzaZa183"
              ><p class="pt-1 font-bold text-yellow-500">
                kunzaZa183
              </p></a
            >
            <a href="https://codeforces.com/profile/Namkhing"
              ><p class="pt-1 font-bold text-blue-400">
                Namkhing
              </p></a
            >
            <a href="https://codeforces.com/profile/peteza"
              ><p class="pt-1 font-bold text-yellow-500">peteza</p></a
            >
            <a href="https://codeforces.com/profile/blackslex"
              ><p class="pt-1 font-bold text-blue-400">blackslex</p></a
            >
            <a href="https://codeforces.com/profile/IceBorworntat"
              ><p class="pt-1 font-bold text-purple-400">
                Hydrolyzed~
              </p></a
            >
            <a href="https://codeforces.com/profile/teakteak"
              ><p class="pt-1 font-bold text-teal-400">teakteak</p></a
            >
            <a href="https://codeforces.com/profile/spycoderyt"
              ><p class="pt-1 font-bold text-purple-400">spycoderyt</p></a
            >
            <!-- <a href="https://codeforces.com/profile/NortGlG"
              ><p class="pt-1 font-bold text-purple-400">NortGlG</p></a
            >
            <a href="https://codeforces.com/profile/RuffLogix"
              ><p class="pt-1 font-bold text-green-600">
                RuffLogix
              </p></a
            >
            <a href="https://codeforces.com/profile/sleepntsheep"
              ><p class="pt-1 font-bold text-purple-400">
                sleepntsheep
              </p></a
            >
            <h2 class="col-span-3 text-2xl md:text-3xl font-bold my-5">
              โจทย์ had been <span class="text-pink-300">ทดสอบed</span> by
            </h2>
            <a href="https://codeforces.com/profile/thawin.ice"
              ><p class="pt-1 font-bold text-purple-400">
                thawin.ice
              </p></a
            >
            <a href="https://codeforces.com/profile/peteza"
              ><p class="pt-1 font-bold text-yellow-500">peteza</p></a
            >
            <a href="https://codeforces.com/profile/8pete8"
              ><p class="pt-1 font-bold text-purple-400">8pete8</p></a
            >
            <a href="https://codeforces.com/profile/Spad2e"
              ><p class="pt-1 font-bold text-blue-500">Spad2e</p></a
            >
            <a href="https://codeforces.com/profile/pakpim"
              ><p class="pt-1 font-bold text-purple-400">pakpim</p></a
            >
            <a href="https://codeforces.com/profile/Marszpace"
              ><p class="pt-1 font-bold text-blue-500">Marszpace</p></a
            > -->
          </div>
          <button class="rounded-md bg-green-600 px-4 py-1 text-sm mt-8">
            <a
              href="#prize"
            >
              <p class="text-white">next</p>
            </a>
          </button>
          <h2 class="text-3xl font-bold pt-3 text-slate-800">Special Thanks</h2>
          
          <a href="#prize"
            ><p class="pt-1 font-bold text-slate-800 text-3xl ">Gemini</p></a
          >
        </div>
      </div>

      <div class="h-screen" id="prize">
        <div
          class="h-full flex flex-col justify-center items-center text-center"
        >
          <h2 class="text-3xl font-bold">รางวัล</h2>
          <button
            id="reveal-prize"
            class="mt-3 rounded-md bg-purple-400 px-4 py-1"
            >Click Here to Reveal!</button
          >
        </div>
      </div>

      <div class="h-screen" id="register">
        <div class="h-full flex flex-col md:flex-row justify-center items-center gap md:gap-16">
          <div class="h-80 md:h-full flex flex-col justify-center items-center">
            <h2 class="text-3xl font-bold">
              <!-- ณ ระบบ <span class="text-[#f6c43d]">Cod</span><span
              class="text-[#1789CA]"
              >efor<span class="text-[#da2828]">ces</span>
            </span> -->
              ณ ระบบ
            </h2>
            <!-- <div class="flex justify-center items-center overflow-hidden"
          style="width: 120px; height: 40px"> -->
            <Image src={cms} alt="sponsor" class="h-1/3 md:h-1/8 w-auto" />
          </div>
          <div class="h-80 md:h-full flex flex-col justify-center items-center">
            <div class="text-2xl flex flex-row">
              <p class="text-blue-400">ติดต</p>
              <p class="text-yellow-200">าม</p>
              <p>&nbsp;</p>
              <p class="text-green-300">ข้าวสาร</p>
              <p>&nbsp;</p>
              <p><span>ที่</span></p>
            </div>
            <Image src={discord} alt="sponsor" class="h-1/4 md:h-1/8 w-auto" />
            <!-- </div> -->
            <div class="pt-3 text-2xl flex flex-row">
              <p class="text-green-400 py-1">เข้าได้</p>
              <p>&nbsp;</p>
              <div>
                <button class="rounded-md bg-cyan-600 px-4 py-1">
                  <a
                    href="https://discord.gg/88VdevjVRV"
                    target="_blank"
                    rel="noopener"
                  >
                    <!-- <a
                  href="https://codeforces.com/group/y3JXgQG05K/contests"
                  target="_blank"
                  rel="noopener"> -->
                    <p class="text-white">ที่นี่</p>
                  </a>
                </button>
              </div>
              <a href="#gean"
                ><ArrowLeft
                  width={30}
                  fill="orange"
                  class="pl-1 animate-bounce-horizontal"
                  stroke-width="30"
                /></a
              >
            </div>
          </div>
        </div>
      </div>

      <div class="h-screen" id="gean">
        <div class="h-full flex flex-col items-center">
          <div class="h-full flex items-center">
            <h1 class="text-3xl font-bold">
              <span><a href="#greet">อ้าว</a></span><span
                class="text-purple-400"
                ><a href="#backshot">ไม่มีอะไร :D</a></span
              >
            </h1>
          </div>
          <div class="mb-5">
            <p class="text-xl">
              Made with ❤️ by <a href="https://github.com/gean-dev">Gean Dev</a>
            </p>
          </div>
        </div>
      </div>

      <!-- <div class="h-screen" id="backshot">
        <div class="h-full flex flex-col items-center">
          <div class="h-full flex flex-col items-center mt-40 gap-y-10">
            <h1 class="text-3xl font-bold">
              <span><a href="#greet">มีแล้ว</a></span><span
                class="text-orange-400"> :)</span
              >
            </h1>
            <Image src={backshot} alt="sponsor" class="h-1/2 w-auto" />
          </div>
          <div class="mb-5">
            <p class="text-xl">
              Made with ❤️ by <a href="https://github.com/gean-dev">Gean Dev</a>
            </p>
          </div>
        </div>
      </div> -->
    </div>
  </main>

  <script>
    document.getElementById("reveal-prize")!.addEventListener("click", () => {
      if (
        document.getElementById("reveal-prize")!.innerHTML !=
        `
          <p>พิเศษสำหรับ 16 อันดับแรก ได้ 0️⃣ บาท</p>
          <button class="rounded-md bg-green-600 px-4 py-1 text-sm">
            <a
              href="#register"
            >
              <p class="text-white">next</p>
            </a>
          </button>
        `
      ) {
        document.getElementById("reveal-prize")!.innerHTML =
        `
          <p>พิเศษสำหรับ 16 อันดับแรก ได้ 0️⃣ บาท</p>
          <button class="rounded-md bg-green-600 px-4 py-1 text-sm">
            <a
              href="#register"
            >
              <p class="text-white">next</p>
            </a>
          </button>
        `
        document
          .getElementById("reveal-prize")!
          .classList.remove("bg-purple-400");
        document.getElementById("reveal-prize")!.classList.add("text-6xl");
        document.getElementById("reveal-prize")!.classList.add("md:text-8xl");
      } else {
        document
          .querySelector("#register")!
          .scrollIntoView({ behavior: "smooth" });
      }
    });
  </script></Layout
>
